<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{% if page.title %}{{ page.title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="author" content="{{ site.name }}" />
  <meta name="description" content="{{ page.description | default: site.description | default: 'Probabilistic machine learning research by Luis A. Ortega.' }}" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="/css/site.css" rel="stylesheet" />
</head>
<body class="site-body nav-{{ page.nav_key | default: 'none' }}">
  {% assign nav_key = page.nav_key | default: '' %}
  <header class="site-header">
    <div class="site-header__inner">
      <a class="site-brand" href="/" aria-label="Luis A. Ortega home">
        <span class="brand-mark">LAO</span>
        <span class="brand-copy">
          <span class="brand-name">Luis A. Ortega</span>
          <span class="brand-field">probabilistic machine learning</span>
        </span>
      </a>

      <nav class="desktop-nav" aria-label="Primary navigation">
        <a class="nav-link{% if nav_key == 'research' %} is-active{% endif %}" href="/">Research</a>
        <a class="nav-link{% if nav_key == 'publications' %} is-active{% endif %}" href="/publications/">Publications</a>
        <a class="nav-link{% if nav_key == 'code' %} is-active{% endif %}" href="/code/">Code</a>
        <a class="nav-link{% if nav_key == 'education' %} is-active{% endif %}" href="/education/">Education</a>
        <a class="nav-link" href="/data/cv.pdf">CV</a>
        <a class="nav-link{% if nav_key == 'contact' %} is-active{% endif %}" href="/contact/">Contact</a>
      </nav>

      <details class="mobile-nav">
        <summary aria-label="Open navigation">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <nav aria-label="Mobile navigation">
          <a href="/">Research</a>
          <a href="/publications/">Publications</a>
          <a href="/code/">Code</a>
          <a href="/education/">Education</a>
          <a href="/data/cv.pdf">CV</a>
          <a href="/contact/">Contact</a>
        </nav>
      </details>
    </div>
  </header>

  {{ content }}

  <footer class="site-footer">
    <div class="page-shell site-footer__inner">
      <span>Luis A. Ortega</span>
      <span>probabilistic machine learning</span>
    </div>
  </footer>
  <script src="/js/site.js"></script>
</body>
</html>
